replicaCount: 1

image:
  repository: ghcr.io/{{ github_owner }}/{{ project_slug }}
  pullPolicy: IfNotPresent
  tag: ""  # falls leer: .Chart.AppVersion wird verwendet

serviceAccount:
  create: true
  name: ""

service:
  type: ClusterIP
  port: 80
  targetPort: 8000

env:
  ENVIRONMENT: PRODUCTION
  LOG_LEVEL: INFO

envFromSecret: ""  # falls leer: <fullname>-env

resources: {}

livenessProbe:
  httpGet:
    path: /health/live
    port: http
  initialDelaySeconds: 5
  periodSeconds: 10

readinessProbe:
  httpGet:
    path: /health/ready
    port: http
  initialDelaySeconds: 5
  periodSeconds: 10

ingress:
  enabled: false
  className: ""
  hosts: []
  tls: []

autoscaling:
  enabled: false
  minReplicas: 1
  maxReplicas: 5
  targetCPUUtilizationPercentage: 80